#!/bin/rc
# Tests for emph=/noemph 9P control verbs (in nctl file).
#
# Uses 9p(1) to talk directly to acme's 9P server via the unix socket,
# avoiding the FUSE session restriction that blocks writes from processes
# outside the mounting session.
#
# Requires a running acme instance.  Detection is done via 9p connectivity,
# not /mnt/acme presence.

addr='unix!'`{9 namespace}^'/acme'

if(! 9p -a $addr read new/ctl >/dev/null >[2]/dev/null) {
	echo 'SKIP: acme 9P server not reachable at '^$addr
	exit 77
}

winid=`{9p -a $addr read new/ctl | awk '{print $1; exit}'}
if(~ $#winid 0 || ~ $winid '') {
	echo 'SKIP: unable to obtain a fresh acme window id'
	exit 77
}

npass=0
nfail=0

fn check {
	got=$status
	expected=$1
	label=$2
	# pipeline status is '|' on success (both sides exit 0 -> empty|empty);
	# non-pipeline success is ''.  Failure: '|1' (echo ok, 9p errored).
	if(~ $expected pass) {
		if(~ $got '' '|') {
			echo PASS: $label
			npass=`{expr $npass + 1}
		}
		if not {
			echo FAIL: $label '(expected success, got '^$got^')'
			nfail=`{expr $nfail + 1}
		}
	}
	if not {
		if(! ~ $got '' '|') {
			echo PASS: $label
			npass=`{expr $npass + 1}
		}
		if not {
			echo FAIL: $label '(expected failure, got success)'
			nfail=`{expr $nfail + 1}
		}
	}
}

fn ctl {
	echo $1 | 9p -a $addr write $winid/ctl
}

fn nctl {
	echo $1 | 9p -a $addr write $winid/nctl >[2]/dev/null
}

# T01: emph=foo accepted
nctl 'emph=foo'
check pass 'T01 emph=foo'

# T02: emph= (empty pattern) rejected with Ebadctl
nctl 'emph='
check fail 'T02 emph= rejected'

# T03: invalid regex silently accepted (warning in +Errors, no 9P error)
nctl 'emph=[unclosed'
check pass 'T03 emph=[unclosed parsed'

# T04: noemph accepted
nctl 'noemph'
check pass 'T04 noemph'

# T06: two verbs in one write
{echo 'emph=foo'; echo 'noemph'} | 9p -a $addr write $winid/nctl
check pass 'T06 emph=foo + noemph in one write'

# cleanup
ctl 'del'

echo '=== Summary ==='
echo $npass' PASS / '$nfail' FAIL'

if(test $nfail -gt 0) exit 1
exit 0
